<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Test model fields exist only to give the reflection walk types to traverse; their values are never read. -->
    <NoWarn>$(NoWarn);CS0649</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- Link the pure analyzer source directly (it has no Unity/Newtonsoft/BepInEx deps) so tests run standalone,
       without loading the Unity-coupled mod assembly. -->
  <ItemGroup>
    <Compile Include="../Source/Savestates/Snapshot/SerializabilityAnalyzer.cs" />
  </ItemGroup>

</Project>